{
  "name": "praeforma-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Praeforma backend (Hono + Drizzle + Postgres + Cernere PASETO)",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=.env.secrets --env-file-if-exists=.env bootstrap.ts",
    "start": "tsx --env-file-if-exists=.env.secrets --env-file-if-exists=.env bootstrap.ts",
    "local": "tsx src/local.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "migrate": "tsx scripts/migrate.ts",
    "env:setup": "npx tsx ../../Cernere/packages/env-cli/src/cli.ts setup",
    "env:test": "npx tsx ../../Cernere/packages/env-cli/src/cli.ts test",
    "env:gen": "npx tsx ../../Cernere/packages/env-cli/src/cli.ts env",
    "env:list": "npx tsx ../../Cernere/packages/env-cli/src/cli.ts list",
    "env:get": "npx tsx ../../Cernere/packages/env-cli/src/cli.ts get",
    "env:set": "npx tsx ../../Cernere/packages/env-cli/src/cli.ts set"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "better-sqlite3": "^12.11.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.6.10",
    "paseto": "^3.1.4",
    "pg": "^8.13.1",
    "tsx": "^4.21.0",
    "ulid": "^2.3.0",
    "ws": "^8.20.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.10",
    "@types/ws": "^8.5.13",
    "typescript": "^5.6.0"
  }
}
