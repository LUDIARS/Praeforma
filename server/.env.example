# Praeforma backend env (copy to .env or use env-cli + Infisical)

# HTTP listen port
PRAEFORMA_PORT=8889

# Postgres connection (LUDIARS shared infra default)
PRAEFORMA_DATABASE_URL=postgres://praeforma:praeforma@localhost:5432/praeforma

# Cernere base URL (PASETO public key fetch)
CERNERE_BASE_URL=http://localhost:8080

# Praeforma own public URL (PASETO audience claim)
PRAEFORMA_PUBLIC_URL=http://localhost:8889

# Cernere project key (issued in Cernere admin UI)
PRAEFORMA_PROJECT_KEY=praeforma
